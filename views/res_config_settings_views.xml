<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_solar" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.solar</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="90"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Cotizador Solar" string_id="cotizador_solar" name="cotizador_solar">
                    <block title="Configuración de Precios por Defecto" name="solar_pricing_defaults">
                        <setting id="solar_pricing_setting" string="Valores Racionales Rápidos" help="Configure los valores por defecto que tomará el cotizador solar en Modo Rápido.">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="solar_quick_price" class="col-lg-4 o_light_label"/>
                                    <field name="solar_quick_price" class="oe_inline"/>
                                </div>
                                <div class="row mt16">
                                    <label for="solar_quick_min_price" class="col-lg-4 o_light_label"/>
                                    <field name="solar_quick_min_price" class="oe_inline"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

    <record id="action_solar_config_settings" model="ir.actions.act_window">
        <field name="name">Configuración</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="context">{'module': 'cotizador_solar'}</field>
    </record>
</odoo>
