<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="module_category_solar" model="ir.module.category">
            <field name="name">Cotizador Solar</field>
            <field name="description">Categoría para la gestión del dimensionamiento y cotización solar.</field>
            <field name="sequence">20</field>
        </record>

        <record id="group_solar_user" model="res.groups">
            <field name="name">Usuario</field>
            <field name="category_id" ref="module_category_solar"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_solar_manager" model="res.groups">
            <field name="name">Administrador</field>
            <field name="category_id" ref="module_category_solar"/>
            <field name="implied_ids" eval="[(4, ref('group_solar_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>
    </data>
</odoo>
