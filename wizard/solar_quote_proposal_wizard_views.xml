<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_solar_quote_proposal_wizard_form" model="ir.ui.view">
        <field name="name">solar.quote.proposal.wizard.form</field>
        <field name="model">solar.quote.proposal.wizard</field>
        <field name="arch" type="xml">
            <form string="Generar Propuesta">
                <group>
                    <field name="solar_quote_id" invisible="1"/>
                    <field name="template_id" options="{'no_create': True, 'no_open': True}"/>
                </group>
                <footer>
                    <button name="action_generate" string="Generar" type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
